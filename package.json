{
  "name": "hugo-entitlement-importer-desktop",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.9.0 <12"
  },
  "scripts": {
    "start": "pnpm run dev",
    "dev": "concurrently -k -n web,electron -c cyan,magenta \"pnpm run dev:web\" \"pnpm run dev:electron\"",
    "dev:web": "pnpm --filter @hugo-entitlement-importer/web dev",
    "dev:electron": "wait-on http://127.0.0.1:5173 && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:5173 pnpm --filter @hugo-entitlement-importer/electron dev",
    "build": "pnpm run typecheck && pnpm run prepare:renderer && pnpm --filter @hugo-entitlement-importer/electron build",
    "prepare:renderer": "pnpm run build:charts && pnpm run build:web",
    "build:charts": "pnpm --filter @hugo-entitlement-importer/charts build",
    "build:web": "pnpm --filter @hugo-entitlement-importer/web build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "wait-on": "^9.0.10"
  }
}
